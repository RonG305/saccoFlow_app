  "info": {
    "title": "ICMS Auth Service API",
    "description": "ICMS auth service backend API documentation",
    "version": "1.0",
    "contact": {

    }
  },
  "tags": [
    {
      "name": "auth service",
      "description": ""
    }
  ],
  "servers": [],
  "components": {
    "securitySchemes": {
      "jwt-auth": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http",
        "description": "Enter JWT token",
        "in": "header"
      }
    },
    "schemas": {
      "CreateUserDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "john.doe@example.com"
          },
          "password": {
            "type": "string",
            "example": "StrongPass123!"
          },
          "confirm_password": {
            "type": "string",
            "example": "StrongPass123!"
          },
          "accept_terms_conditions": {
            "type": "boolean",
            "example": true
          },
          "account_type": {
            "type": "string",
            "enum": [
              "individual",
              "origanization"
            ],
            "example": "individual"
          },
          "first_name": {
            "type": "string",
            "example": "John"
          },
          "last_name": {
            "type": "string",
            "example": "Doe"
          },
          "middle_name": {
            "type": "string",
            "example": "A."
          },
          "phone_number": {
            "type": "string",
            "example": "+254722334455"
          },
          "alternative_phone": {
            "type": "string",
            "example": "+254711000000"
          },
          "gender": {
            "type": "string",
            "enum": [
              "male",
              "female",
              "other"
            ],
            "example": "male"
          },
          "date_of_birth": {
            "type": "string",
            "example": "1990-01-01"
          },
          "bio": {
            "type": "string",
            "example": "Short bio about the user"
          },
          "avatar_url": {
            "type": "string",
            "example": "https://example.com/avatar.jpg"
          },
          "national_id": {
            "type": "string",
            "example": "12345678"
          },
          "national_id_type": {
            "type": "string",
            "example": "National ID"
          },
          "street_address": {
            "type": "string",
            "example": "123 Main St"
          },
          "city": {
            "type": "string",
            "example": "Nairobi"
          },
          "region": {
            "type": "string",
            "example": "Nairobi County"
          },
          "postal_code": {
            "type": "string",
            "example": "00100"
          },
          "country": {
            "type": "string",
            "example": "Kenya"
          },
          "address_type": {
            "type": "string",
            "example": "Residence",
            "description": "Residence, Work, Billing, Shipping"
          },
          "organization_id": {
            "type": "string",
            "example": "clorg123abc",
            "description": "Organization the user belongs to"
          }
        },
        "required": [
          "email",
          "password",
          "confirm_password",
          "accept_terms_conditions",
          "first_name",
          "last_name"
        ]
      },
      "LoginDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "customer@example.com"
          },
          "password": {
            "type": "string",
            "example": "strongPassword123!"
          },
          "organization_id": {
            "type": "string",
            "example": "clorg123abc",
            "description": "Organization ID the user is logging into. Required for org-scoped access."
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "VerifyLoginOtpDto": {
        "type": "object",
        "properties": {
          "pre_auth_token": {
            "type": "string",
            "description": "pre_auth_token returned from POST /login"
          },
          "otp": {
            "type": "string",
            "example": "748302",
            "description": "6-digit OTP sent to your email"
          }
        },
        "required": [
          "pre_auth_token",
          "otp"
        ]
      },
      "RequestPasswordChangeDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "user@example.com"
          }
        },
        "required": [
          "email"
        ]
      },
      "ConfirmPasswordChangeDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "user@example.com"
          },
          "otp": {
            "type": "string",
            "example": "483921",
            "description": "6-digit OTP sent to your email"
          },
          "new_password": {
            "type": "string",
            "example": "NewSecurePass!9"
          },
          "confirm_password": {
            "type": "string",
            "example": "NewSecurePass!9"
          }
        },
        "required": [
          "email",
          "otp",
          "new_password",
          "confirm_password"
        ]
      },
      "UpdateUserDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "john.doe@example.com"
          },
          "password": {
            "type": "string",
            "example": "StrongPass123!"
          },
          "confirm_password": {
            "type": "string",
            "example": "StrongPass123!"
          },
          "accept_terms_conditions": {
            "type": "boolean",
            "example": true
          },
          "account_type": {
            "type": "string",
            "enum": [
              "individual",
              "origanization"
            ],
            "example": "individual"
          },
          "first_name": {
            "type": "string",
            "example": "John"
          },
          "last_name": {
            "type": "string",
            "example": "Doe"
          },
          "middle_name": {
            "type": "string",
