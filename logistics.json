      }
    },
    "schemas": {
      "CreateVehicleDto": {
        "type": "object",
        "properties": {
          "reg_number": {
            "type": "string",
            "example": "KCA 123A",
            "description": "Unique vehicle registration number"
          },
          "make": {
            "type": "string",
