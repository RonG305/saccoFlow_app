            "description": "Specific model name"
          },
          "year": {
            "type": "number",
            "minimum": 1900,
            "example": 2024,
            "description": "Year of manufacture"
          },
          "capacity_liters": {
            "type": "number",
            "minimum": 1,
            "example": 60,
            "description": "Fuel tank capacity in litres"
          },
          "fuel_type": {
